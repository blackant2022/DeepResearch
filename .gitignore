# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/

# ===== 密钥 / 敏感配置（严禁入库）=====
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
credentials.json
secrets.json
**/secrets/**
**/credentials/**

# IDE / 工具
.idea/
.cursor/
.vscode/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# 向量库 & 检查点（本地生成，不入库）
data/chroma/*
data/ltm_chroma/*
data/checkpoints/*
!data/**/.gitkeep

# 用户上传的文献（体积大，不入库；请自行放入 data/docs）
data/docs/*
!data/docs/.gitkeep

# 本地评测输出（可含机器路径，默认不入库；需要时可手动 add）
data/eval/*

# 二进制 / 缓存 / 日志
*.bin
*.sqlite3
.cache/
fastembed_cache/
*.log
logs/
