# ============================================================
# DeepResearch — 环境变量模板（可提交 Git）
# 复制为 .env 后填入真实 Key：  copy .env.example .env
# 真实密钥禁止写进本文件、settings.py、README、截图
# ============================================================

# ---- DeepSeek（https://platform.deepseek.com）----
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# ---- 嵌入模型 ----
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5

# ---- RAG 分块（语义断点 + 长段滑动窗口）----
CHUNK_SIZE=500
CHUNK_OVERLAP=60
CHUNK_OVERLAP_RATIO=0.12
CHUNK_MIN_SIZE=40
SEMANTIC_SPLIT_THRESHOLD=0.55
TOP_K=3
RETRIEVAL_RECALL_K=16

# ---- 重排序（auto=优先 Cross-Encoder，失败回退稠密重打分）----
RERANK_ENABLED=true
RERANK_BACKEND=auto
RERANK_MODEL=Xenova/ms-marco-MiniLM-L-6-v2
RERANK_MIN_SCORE=0.35

# ---- 领域词典 / 向量增强 ----
DOMAIN_LEXICON_ENABLED=true
DOMAIN_LEXICON_PATH=data/domain_lexicon.json
DOMAIN_EMBED_BLEND=0.15

# ---- 问答置信度兜底 ----
ANSWER_CONFIDENCE_ENABLED=true
ANSWER_CONFIDENCE_THRESHOLD=0.45

# ---- 多模态（可选；不填则复用 DEEPSEEK_*）----
MULTIMODAL_ENABLED=true
# MULTIMODAL_API_KEY=
# MULTIMODAL_BASE_URL=
# MULTIMODAL_MODEL=
MULTIMODAL_MAX_TOKENS=2048
CHAT_ATTACHMENT_MAX_DOC_CHARS=12000

# ---- 运行参数（快路径）----
FAST_MODE=true
MAX_REPLAN=2
MAX_TOOL_RETRY=3
GROUNDING_THRESHOLD=0.6
RETRIEVAL_THRESHOLD=0.55
MAX_REACT_ITERATIONS=4
PARALLEL_TOOLS=true
QUERY_REWRITE_ENABLED=false

# ---- MCP（可选）----
MCP_CLIENT_ENABLED=false
# MCP_SERVERS=[{"command":"python","args":["run_mcp_server.py"],"prefix":"dr"}]

# ---- 联网搜索 ----
WEB_SEARCH_PROVIDER=auto
# TAVILY_API_KEY=
TAVILY_SEARCH_DEPTH=basic
WEB_SEARCH_MAX_RESULTS=5
WEB_SEARCH_REGION=cn-zh
