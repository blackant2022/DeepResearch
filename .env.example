# ==== DeepSeek（去 platform.deepseek.com 免费注册获取 Key）====
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# ==== 嵌入模型（FastEmbed ONNX，首次检索自动下载，约 30MB）====
# 可选：BAAI/bge-small-zh-v1.5（中文，默认）| BAAI/bge-small-en-v1.5（英文）
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5

# ==== 多模态（OpenAI 兼容视觉 API）====
# 图片理解用；文档附件自动提取文本，无需视觉模型
MULTIMODAL_ENABLED=true
MULTIMODAL_API_KEY=sk-kamngwJhxRp8bBdGXooK2ImRAgvIJXWF39Hf78WCJBl7mFdE
MULTIMODAL_BASE_URL=https://api.qingyuntop.top/v1
MULTIMODAL_MODEL=gpt-5-mini-2025-08-07
MULTIMODAL_MAX_TOKENS=2048
CHAT_ATTACHMENT_MAX_DOC_CHARS=12000

# ==== 运行参数 ====
MAX_REPLAN=2
MAX_TOOL_RETRY=3
GROUNDING_THRESHOLD=0.6
RETRIEVAL_THRESHOLD=0.55
MAX_REACT_ITERATIONS=8
QUERY_REWRITE_ENABLED=true

# ==== MCP（Model Context Protocol）====
# 启动本地 MCP Server：python run_mcp_server.py
MCP_CLIENT_ENABLED=false
# MCP_SERVERS=[{"command":"python","args":["run_mcp_server.py"],"prefix":"dr"}]

# ==== 联网搜索（二选一或自动）====
# auto：配置了 TAVILY_API_KEY 则用 Tavily，否则用 DuckDuckGo（免费）
WEB_SEARCH_PROVIDER=auto
# Tavily（推荐，https://tavily.com 免费额度）
TAVILY_API_KEY=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
TAVILY_SEARCH_DEPTH=basic
WEB_SEARCH_MAX_RESULTS=5
WEB_SEARCH_REGION=cn-zh
