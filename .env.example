# ==== DeepSeek（去 platform.deepseek.com 免费注册获取 Key）====
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# ==== 嵌入模型（FastEmbed ONNX，首次检索自动下载，约 30MB）====
# 可选：BAAI/bge-small-zh-v1.5（中文，默认）| BAAI/bge-small-en-v1.5（英文）
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5

# ==== 运行参数 ====
MAX_REPLAN=2
MAX_TOOL_RETRY=3
GROUNDING_THRESHOLD=0.6
